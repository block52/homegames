{
    "compilerOptions": {
        "lib": ["ES2020"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    }
}
