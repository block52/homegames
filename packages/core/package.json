        "@rollup/plugin-typescript": "^12.1.1",
        "@types/better-sqlite3": "^7.6.11",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.7.6",
        "eslint": "^9.0.0",
        "jest": "^29.7.0",
        "rimraf": "^6.0.1",
        "rollup": "^4.28.1",
        "rollup-plugin-dts": "^6.1.1",
        "ts-jest": "^29.2.5",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.0.0"
